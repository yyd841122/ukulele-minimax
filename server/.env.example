# 应用配置
APP_NAME="AI 音乐学园"
APP_VERSION="0.1.0"
DEBUG=true

# API
API_V1_PREFIX=/api/v1

# 数据库（开发用 SQLite，生产换 PostgreSQL）
DATABASE_URL=sqlite+aiosqlite:///./data/ukulele.db

# Redis（可选，缓存）
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-in-production-please
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI 模型（云端用 CREPE，端侧走 Flutter）
CREPE_MODEL=full
CREPE_FMIN=50.0
CREPE_FMAX=2006.0

# 跨域（CORS）
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]