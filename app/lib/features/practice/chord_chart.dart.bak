import 'package:flutter/material.dart';

/// 尤克里里按键图（弦 + 品位的简化指法图）
///
/// 尤克里里标准调弦（G C E A），从左到右是第 4 弦到第 1 弦（演奏视角）
/// 4 弦 = G（最粗/最高音）  3 弦 = C  2 弦 = E  1 弦 = A（最细/最低音）
///
/// 显示规则：
/// - 数字 = 左手按的品位（1-4），0 = 空弦
/// - ✕ = 不弹
/// - 圆点 = 按住品位的指位圆圈
class ChordChart extends StatelessWidget {
  const ChordChart({
    super.key,
    required this.chord,
    this.isSingle = false,
  });

  final String chord;
  final bool isSingle;

  /// 单音推荐按法（尤克里里 GCEA 标准调弦）
  /// key = 音名 (C4 / D4 等)，value = [_SingleNotePosition]
  /// 优先选择空弦或 1-3 品内的"自然位置"，让新手能轻松上手
  static const Map<String, _SingleNotePosition> _singleNotes = {
    // C4 = 1 弦(A) 3 品（也可空弦 3 弦，但 1 弦更稳）
    'C': _SingleNotePosition(
      note: 'C4',
      fingerings: <int?>[null, null, null, 3],
      finger: <int?>[null, null, null, 3],
      description: '1弦（A弦）3品，用无名指',
    ),
    // C5 = 1 弦(A) 15 品（太远）→ 实际用 3 弦(C) 12 品或别的位置
    // 但我们关心常用 C4，简化方案
    'D': _SingleNotePosition(
      note: 'D4',
      fingerings: <int?>[null, null, 2, null],
      finger: <int?>[null, null, 2, null],
      description: '2弦（E弦）2品，用中指',
    ),
    'E': _SingleNotePosition(
      note: 'E4',
      fingerings: <int?>[null, null, 0, null],
      finger: <int?>[null, null, null, null],
      description: '2弦（E弦）空弦',
    ),
    'F': _SingleNotePosition(
      note: 'F4',
      fingerings: <int?>[1, null, null, null],
      finger: <int?>[1, null, null, null],
      description: '4弦（G弦）1品，用食指',
    ),
    'G': _SingleNotePosition(
      note: 'G4',
      fingerings: <int?>[0, null, null, null],
      finger: <int?>[null, null, null, null],
      description: '4弦（G弦）空弦',
    ),
    'A': _SingleNotePosition(
      note: 'A4',
      fingerings: <int?>[null, null, null, 0],
      finger: <int?>[null, null, null, null],
      description: '1弦（A弦）空弦',
    ),
    'B': _SingleNotePosition(
      note: 'B4',
      fingerings: <int?>[2, null, null, null],
      finger: <int?>[2, null, null, null],
      description: '4弦（G弦）2品，用中指',
    ),
    // 高音区（八度 + 7）
    'D5': _SingleNotePosition(
      note: 'D5',
      fingerings: <int?>[null, null, null, 5],
      finger: <int?>[null, null, null, 4],
      description: '1弦 5 品',
    ),
    'E5': _SingleNotePosition(
      note: 'E5',
      fingerings: <int?>[null, 4, null, null],
      finger: <int?>[null, 4, null, null],
      description: '3弦 4 品',
    ),
    'G5': _SingleNotePosition(
      note: 'G5',
      fingerings: <int?>[null, null, 3, null],
      finger: <int?>[null, null, 3, null],
      description: '2弦 3 品',
    ),
    'A5': _SingleNotePosition(
      note: 'A5',
      fingerings: <int?>[null, null, null, 7],
      finger: <int?>[null, null, null, 4],
      description: '1弦 7 品',
    ),
    'B5': _SingleNotePosition(
      note: 'B5',
      fingerings: <int?>[null, null, 5, null],
      finger: <int?>[null, null, 4, null],
      description: '2弦 5 品',
    ),
  };

  /// 常见和弦指法（尤克里里标准 GCEA 调弦）
  /// 数据: 4 弦(G), 3 弦(C), 2 弦(E), 1 弦(A) - 演奏者视角从左到右
  static const Map<String, _ChordFingering> _chords = {
    'C': _ChordFingering(
      fingerings: <int?>[0, 0, 0, 3],
      finger: <int?>[null, null, null, 3],
    ),
    'Am': _ChordFingering(
      fingerings: <int?>[0, 0, 0, 0],
      finger: <int?>[null, null, null, null],
    ),
    'F': _ChordFingering(
      fingerings: <int?>[2, 0, 1, 0],
      finger: <int?>[1, null, 2, null],
    ),
    'G': _ChordFingering(
      fingerings: <int?>[0, 2, 3, 2],
      finger: <int?>[null, 1, 2, 3],
    ),
    'D': _ChordFingering(
      fingerings: <int?>[2, 2, 2, 0],
      finger: <int?>[1, 2, 3, null],
    ),
    'Dm': _ChordFingering(
      fingerings: <int?>[2, 2, 2, 0],
      finger: <int?>[1, 2, 3, null],
    ),
    'E': _ChordFingering(
      fingerings: <int?>[4, 4, 4, 4],
      finger: <int?>[1, 2, 3, 4],
    ),
    'Em': _ChordFingering(
      fingerings: <int?>[0, 4, 3, 2],
      finger: <int?>[null, 3, 2, 1],
    ),
  };

  @override
  Widget build(BuildContext context) {
    // 1. 如果外部明确指定 isSingle → 强制走单音图
    if (isSingle) {
      final String root = chord.isNotEmpty ? chord[0] : '-';
      final _SingleNotePosition? pos = _singleNotes[root];
      if (pos != null) {
        return _SingleNoteDiagram(position: pos);
      }
      // 找不到 → 占位
      return _UnsupportedChord(chord: chord);
    }

    // 2. 默认查和弦库
    final _ChordFingering? chordMatch = _chords[chord];
    if (chordMatch != null) {
      return _ChordDiagram(label: chord, fingering: chordMatch);
    }

    // 3. 退化：如果不是和弦名（m/# 等）但 root 是合法音 → 当单音
    final String root = chord.isNotEmpty ? chord[0] : '-';
    if (RegExp(r'^[A-G]$').hasMatch(root)) {
      final bool looksLikeChord =
          chord.length > 1 && (chord[1] == 'm' || chord[1] == '#');
      if (!looksLikeChord) {
        final _SingleNotePosition? pos = _singleNotes[root];
        if (pos != null) {
          return _SingleNoteDiagram(position: pos);
        }
      }
    }

    return _UnsupportedChord(chord: chord);
  }
}

class _SingleNotePosition {
  const _SingleNotePosition({
    required this.note,
    required this.fingerings,
    required this.finger,
    required this.description,
  });

  final String note;
  final List<int?> fingerings;
  final List<int?> finger;
  final String description;
}

/// 单音指法图
class _SingleNoteDiagram extends StatelessWidget {
  const _SingleNoteDiagram({required this.position});
  final _SingleNotePosition position;

  // 把单音数据转成和 chord 一样的 _ChordFingering 形式，复用指板画法
  _ChordFingering get _asFingering => _ChordFingering(
        fingerings: position.fingerings,
        finger: position.finger,
      );

  @override
  Widget build(BuildContext context) {
    // 单音：只显示指板图（绿色提示框移到 _CurrentChordBig）
    return Column(
      mainAxisSize: MainAxisSize.min,
      children: <Widget>[
        _ChordDiagram(
          label: position.note,
          fingering: _asFingering,
        ),
      ],
    );
  }
}

class _ChordFingering {
  const _ChordFingering({
    required this.fingerings,
    required this.finger,
  });

  /// 每根弦按的品位（null = 不弹 / 0 = 空弦 / 1-4 = 品位）
  final List<int?> fingerings;

  /// 每根弦用哪根手指按（null = 空弦或不弹；1=食指 2=中指 3=无名指 4=小指）
  final List<int?> finger;
}

/// 4 弦尤克里里指法图（简洁版：只画 0 品行 + 指板 + 底部弦标签）
class _ChordDiagram extends StatelessWidget {
  const _ChordDiagram({required this.label, required this.fingering});
  final String label;
  final _ChordFingering fingering;

  @override
  Widget build(BuildContext context) {
    return Container(
      padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 8),
      decoration: BoxDecoration(
        color: Colors.grey.shade50,
        borderRadius: BorderRadius.circular(8),
        border: Border.all(color: Colors.grey.shade200),
      ),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.stretch,
        children: <Widget>[
          // 0 品状态行
          SizedBox(
            height: 20,
            child: LayoutBuilder(
              builder: (BuildContext context, BoxConstraints c) {
                return Row(
                  children: List<Widget>.generate(4, (int s) {
                    final int? f = fingering.fingerings[s];
                    return SizedBox(
                      width: c.maxWidth / 4,
                      child: Center(
                        child: Text(
                          f == 0 ? '○' : (f == null ? '✕' : ''),
                          style: TextStyle(
                            fontSize: 14,
                            color: f == 0
                                ? Colors.green.shade700
                                : Colors.red.shade400,
                            fontWeight: FontWeight.w700,
                          ),
                        ),
                      ),
                    );
                  }),
                );
              },
            ),
          ),
          // 指板：用 Stack 叠 Painter + Overlay，避开 CustomPaint 缓存
          Expanded(
            child: AspectRatio(
              aspectRatio: 0.85,
              child: Stack(
                children: <Widget>[
                  // 底层：只画指板线（无 child = 不被 CustomPaint 缓存影响）
                  Positioned.fill(
                    child: CustomPaint(
                      painter: _FretboardPainter(),
                    ),
                  ),
                  // 顶层：圆点 Overlay（独立 Widget，会随 fingering 自动 rebuild）
                  Positioned.fill(
                    child: _FretboardOverlay(fingering: fingering),
                  ),
                ],
              ),
            ),
          ),
          // 底部弦标签
          Padding(
            padding: const EdgeInsets.only(top: 4),
            child: SizedBox(
              height: 18,
              child: LayoutBuilder(
                builder: (BuildContext context, BoxConstraints c) {
                  return Row(
                    children: const <Widget>[
                      Expanded(
                        child: Center(
                          child: _StringLabel(label: 'G', isFirst: true),
                        ),
                      ),
                      Expanded(
                        child: Center(
                          child: _StringLabel(label: 'C', isFirst: false),
                        ),
                      ),
                      Expanded(
                        child: Center(
                          child: _StringLabel(label: 'E', isFirst: false),
                        ),
                      ),
                      Expanded(
                        child: Center(
                          child: _StringLabel(label: 'A', isFirst: false),
                        ),
                      ),
                    ],
                  );
                },
              ),
            ),
          ),
        ],
      ),
    );
  }
}

/// 画指板：5 条水平线（品丝）+ 4 条垂直线（琴弦）+ 顶部上弦枕
class _FretboardPainter extends CustomPainter {
  @override
  void paint(Canvas canvas, Size size) {
    final Paint stringPaint = Paint()
      ..color = Colors.grey.shade800
      ..strokeWidth = 1.5;
    final Paint fretPaint = Paint()
      ..color = Colors.grey.shade500
      ..strokeWidth = 0.8;
    final Paint nutPaint = Paint()
      ..color = Colors.grey.shade900
      ..strokeWidth = 3.0;

    final double padX = 20.0;
    final double padY = 20.0;
    final double usableW = size.width - 2 * padX;
    final double usableH = size.height - 2 * padY;

    // 4 根琴弦（垂直线，从左到右：4弦 G → 1弦 A）
    for (int s = 0; s < 4; s++) {
      final double x = padX + (s / 3) * usableW;
      canvas.drawLine(
        Offset(x, padY),
        Offset(x, size.height - padY),
        stringPaint,
      );
    }

    // 5 条品丝（水平线：0 品顶部 + 1/2/3/4 品）
    for (int f = 0; f <= 4; f++) {
      final double y = padY + (f / 4) * usableH;
      canvas.drawLine(
        Offset(padX, y),
        Offset(size.width - padX, y),
        f == 0 ? nutPaint : fretPaint,
      );
    }
  }

  @override
  bool shouldRepaint(covariant CustomPainter old) => false;
}

/// 在指板上叠加指位圆点
///
/// 坐标系：
/// - 水平 x = padX + (s/3)*usableW，s=0=G(4弦 最左) → s=3=A(1弦 最右)
/// - 垂直 y = padY + (f/4)*usableH，f=0=0品（顶部） → f=4=4品（底部）
class _FretboardOverlay extends StatelessWidget {
  const _FretboardOverlay({required this.fingering});
  final _ChordFingering fingering;

  @override
  Widget build(BuildContext context) {
    return LayoutBuilder(
      builder: (BuildContext context, BoxConstraints constraints) {
        final double w = constraints.maxWidth;
        final double h = constraints.maxHeight;
        final double padX = 20.0; // 加宽边距防止圆点溢出
        final double padY = 20.0;
        final double usableW = w - 2 * padX;
        final double usableH = h - 2 * padY;

        // 弦 x 坐标：s=0 最左
        double xForString(int s) => padX + (s / 3) * usableW;
        // 品位 y 坐标：f=1 是第 1 条品丝下方
        double yForFret(int fret) => padY + (fret / 4) * usableH;
        // 圆点大小：弦间距的 60%（不溢出到相邻弦）
        final double dotSize = (usableW / 4 * 0.6).clamp(0.0, usableH / 5);
        // 圆点居中：每个品位的中间 y
        double yCenterForFret(int fret) {
          // 弦在 2 个品丝之间
          final double fretY = yForFret(fret);
          final double nextFretY = yForFret(fret + 1);
          return (fretY + nextFretY) / 2;
        }

        return SizedBox(
          width: w,
          height: h,
          child: Stack(
            clipBehavior: Clip.none,
            children: <Widget>[
              for (int s = 0; s < 4; s++)
                for (int f = 1; f <= 4; f++)
                  if (fingering.fingerings[s] == f)
                    Positioned(
                      left: xForString(s) - dotSize / 2,
                      top: yCenterForFret(f) - dotSize / 2,
                      child: Container(
                        width: dotSize,
                        height: dotSize,
                        decoration: BoxDecoration(
                          shape: BoxShape.circle,
                          color: Theme.of(context).colorScheme.primary,
                          boxShadow: <BoxShadow>[
                            BoxShadow(
                              color: Theme.of(context)
                                  .colorScheme
                                  .primary
                                  .withValues(alpha: 0.5),
                              blurRadius: 3,
                            ),
                          ],
                        ),
                        alignment: Alignment.center,
                        child: Text(
                          fingering.finger[s]?.toString() ?? '',
                          style: const TextStyle(
                            fontSize: 10,
                            color: Colors.white,
                            fontWeight: FontWeight.w700,
                          ),
                        ),
                      ),
                    ),
            ],
          ),
        );
      },
    );
  }
}

class _StringColumn extends StatelessWidget {
  const _StringColumn({
    required this.fingerings,
    required this.fingers,
    required this.stringIdx,
    required this.isFirst,
    required this.isLast,
  });

  final List<int?> fingerings;
  final List<int?> fingers;
  final int stringIdx;
  final bool isFirst;
  final bool isLast;

  @override
  Widget build(BuildContext context) {
    const double cellSize = 22;
    const double stringThickness = 1.5;
    final Color stringColor = Colors.grey.shade700;

    return Column(
      mainAxisSize: MainAxisSize.min,
      children: <Widget>[
        // 顶部 0 品位置（如果是 0 就显示 ○，否则显示按的品位）
        SizedBox(
          width: cellSize,
          height: cellSize,
          child: fingerings[stringIdx] == 0
              ? const Center(
                  child: Text(
                    '○',
                    style: TextStyle(fontSize: 14, color: Colors.green),
                  ),
                )
              : fingerings[stringIdx] == null
                  ? const Center(
                      child: Text(
                        '✕',
                        style: TextStyle(
                          fontSize: 12,
                          color: Colors.red,
                        ),
                      ),
                    )
                  : const SizedBox.shrink(),
        ),
        // 4 行品位（每行有竖线分隔，底部有琴弦线）
        for (int fret = 1; fret <= 4; fret++)
          Container(
            width: cellSize,
            height: cellSize,
            decoration: BoxDecoration(
              // 品位之间用横线分隔
              border: Border(
                bottom: BorderSide(
                  color: Colors.grey.shade300,
                  width: 0.5,
                ),
              ),
            ),
            child: Stack(
              alignment: Alignment.center,
              children: <Widget>[
                // 按的品位显示实心圆 + 手指号
                if (fingerings[stringIdx] == fret)
                  Container(
                    width: 18,
                    height: 18,
                    decoration: BoxDecoration(
                      shape: BoxShape.circle,
                      color: Theme.of(context).colorScheme.primary,
                      boxShadow: <BoxShadow>[
                        BoxShadow(
                          color: Theme.of(context)
                              .colorScheme
                              .primary
                              .withValues(alpha: 0.4),
                          blurRadius: 4,
                        ),
                      ],
                    ),
                    alignment: Alignment.center,
                    child: Text(
                      fingers[stringIdx]?.toString() ?? '',
                      style: const TextStyle(
                        fontSize: 11,
                        color: Colors.white,
                        fontWeight: FontWeight.w700,
                      ),
                    ),
                  ),
              ],
            ),
          ),
        // 底部的琴弦线（整条弦画出来）
        Container(
          width: cellSize,
          height: stringThickness,
          color: stringColor,
        ),
        // 琴弦下方留空
        const SizedBox(height: 4),
      ],
    );
  }
}

class _StringLabel extends StatelessWidget {
  const _StringLabel({required this.label, required this.isFirst});
  final String label;
  final bool isFirst;

  @override
  Widget build(BuildContext context) {
    return Text(
      label,
      style: TextStyle(
        fontSize: 11,
        color: Colors.grey.shade600,
        fontWeight: FontWeight.w600,
      ),
    );
  }
}

/// 不支持的和弦：显示和弦名 + 提示用户自行尝试
class _UnsupportedChord extends StatelessWidget {
  const _UnsupportedChord({required this.chord});
  final String chord;

  @override
  Widget build(BuildContext context) {
    return Container(
      padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 24),
      decoration: BoxDecoration(
        color: Colors.grey.shade50,
        borderRadius: BorderRadius.circular(8),
        border: Border.all(color: Colors.grey.shade200),
      ),
      child: Column(
        mainAxisAlignment: MainAxisAlignment.center,
        children: <Widget>[
          Icon(Icons.music_note, size: 36, color: Colors.grey.shade400),
          const SizedBox(height: 8),
          Text(
            chord,
            style: TextStyle(
              fontSize: 28,
              fontWeight: FontWeight.w700,
              color: Colors.grey.shade700,
            ),
          ),
          const SizedBox(height: 8),
          Text(
            '请参考曲谱，或自行尝试按法',
            style: TextStyle(fontSize: 12, color: Colors.grey.shade500),
          ),
        ],
      ),
    );
  }
}